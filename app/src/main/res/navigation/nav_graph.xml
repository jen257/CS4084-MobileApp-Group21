<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- 1. Authentication Flow -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.reloop.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.reloop.ui.auth.RegisterFragment"
        android:label="Register"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_registerFragment_to_loginFragment"
            app:destination="@id/loginFragment" />
    </fragment>

    <!-- 2. Main Tab Interface -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.example.reloop.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_homeFragment_to_productDetailFragment"
            app:destination="@id/productDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/productDetailFragment"
        android:name="com.example.reloop.ui.detail.ProductDetailFragment"
        android:label="Product Detail"
        tools:layout="@layout/fragment_product_detail">
        <argument
            android:name="product"
            app:argType="com.example.reloop.models.Product" />
        <action
            android:id="@+id/action_productDetailFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/postFragment"
        android:name="com.example.reloop.ui.post.PostFragment"
        android:label="Sell"
        tools:layout="@layout/fragment_post" />

    <fragment
        android:id="@+id/messageFragment"
        android:name="com.example.reloop.ui.message.ConversationListFragment"
        android:label="Messages"
        tools:layout="@layout/fragment_conversations">
        <action
            android:id="@+id/action_messageFragment_to_chatFragment"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.example.reloop.ui.message.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat">
        <argument android:name="conversationId" app:argType="string" app:nullable="true" />
        <argument android:name="currentUserId" app:argType="string" app:nullable="true" />
        <argument android:name="otherUserId" app:argType="string" app:nullable="true" />
        <argument android:name="productId" app:argType="string" app:nullable="true" />
    </fragment>

    <!-- Profile Tab Dashboard -->
    <fragment
        android:id="@+id/profileFragment"
        android:name="com.example.reloop.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">
        <action
            android:id="@+id/action_profileFragment_to_editProfileFragment"
            app:destination="@id/editProfileFragment" />
        <action
            android:id="@+id/action_profileFragment_to_settingsFragment"
            app:destination="@id/settingsFragment" />
        <action
            android:id="@+id/action_profileFragment_to_wishlistFragment"
            app:destination="@id/wishlistFragment" />
    </fragment>

    <fragment
        android:id="@+id/wishlistFragment"
        android:name="com.example.reloop.ui.wishlist.WishlistFragment"
        android:label="Wishlist"
        tools:layout="@layout/fragment_wishlist" />

    <!-- 3. Edit Profile (Accessed from Profile Tab) -->
    <fragment
        android:id="@+id/editProfileFragment"
        android:name="com.example.reloop.ui.profile.EditProfileFragment"
        android:label="Edit Profile"
        tools:layout="@layout/fragment_edit_profile">
        <action
            android:id="@+id/action_editProfileFragment_to_securityFragment"
            app:destination="@id/securityFragment" />
        <action
            android:id="@+id/action_editProfileFragment_to_addressFragment"
            app:destination="@id/addressFragment" />
    </fragment>

    <!-- 4. Settings Interface -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.reloop.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settingsFragment_to_personalProfileFragment"
            app:destination="@id/personalProfileFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_addressFragment"
            app:destination="@id/addressFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_securityFragment"
            app:destination="@id/securityFragment" />
        <action
            android:id="@+id/action_settingsFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 5. Personal Profile (Accessed via Settings) -->
    <fragment
        android:id="@+id/personalProfileFragment"
        android:name="com.example.reloop.ui.profile.PersonalProfileFragment"
        android:label="Personal Profile"
        tools:layout="@layout/fragment_personal_profile">
        <action
            android:id="@+id/action_personalProfileFragment_to_securityFragment"
            app:destination="@id/securityFragment" />
        <action
            android:id="@+id/action_personalProfileFragment_to_addressFragment"
            app:destination="@id/addressFragment" />
    </fragment>

    <!-- Common Account Screens -->
    <fragment
        android:id="@+id/addressFragment"
        android:name="com.example.reloop.ui.settings.AddressFragment"
        android:label="Address Management"
        tools:layout="@layout/fragment_address_management" />

    <fragment
        android:id="@+id/securityFragment"
        android:name="com.example.reloop.ui.settings.SecurityFragment"
        android:label="Account Security"
        tools:layout="@layout/fragment_account_security" />

</navigation>