<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address Book"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="16dp"/>

        <!-- List of Saved Addresses -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewAddresses"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:nestedScrollingEnabled="false"/>

        <!-- Button to show the form -->
        <Button
            android:id="@+id/btnShowAddForm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="+ Create New Address"
            android:textAllCaps="false"
            android:backgroundTint="#EEEEEE"
            android:textColor="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- THE INPUT FORM (Hidden by default) -->
        <LinearLayout
            android:id="@+id/layoutAddressForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btnUseGPS"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Locate Me (GPS)"
                android:textAllCaps="false"
                android:drawableStart="@drawable/ic_my_location"
                android:paddingStart="16dp"
                android:backgroundTint="@color/brand_yellow"
                android:textColor="#333333"
                android:layout_marginBottom="24dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Or Type Address Manually"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/etCountry"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_white"
                    android:hint="Country"
                    android:padding="12dp"
                    android:textColor="#333333"
                    android:textColorHint="#9E9E9E"/>

                <EditText
                    android:id="@+id/etCounty"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_white"
                    android:hint="County/State"
                    android:padding="12dp"
                    android:textColor="#333333"
                    android:textColorHint="#9E9E9E"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etCity"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_white"
                android:hint="City/Town"
                android:padding="12dp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"/>

            <EditText
                android:id="@+id/etStreet"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_white"
                android:hint="Street and House number"
                android:padding="12dp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"/>

            <EditText
                android:id="@+id/etPostcode"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_search_white"
                android:hint="Postcode"
                android:padding="12dp"
                android:textColor="#333333"
                android:textColorHint="#9E9E9E"/>

            <Button
                android:id="@+id/btnSaveAddress"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Save Address"
                android:textAllCaps="false"
                android:backgroundTint="@color/brand_yellow"
                android:textColor="#333333"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>