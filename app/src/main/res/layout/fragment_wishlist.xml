<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="16dp">

    <!-- Wishlist Title -->
    <TextView
        android:id="@+id/tv_wishlist_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/my_wishlist"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#333333"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- Wishlist Items: Grid Layout (2 columns like home page) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_wishlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_wishlist_title"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Empty State: Show when wishlist is empty -->
    <TextView
        android:id="@+id/tv_empty_wishlist"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:text="@string/your_wishlist_is_empty_click_the_heart_on_products_to_collect"
        android:textSize="18sp"
        android:textColor="#999999"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tv_wishlist_title"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>