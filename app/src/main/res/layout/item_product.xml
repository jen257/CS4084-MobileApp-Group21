<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    card_view:cardCornerRadius="12dp"
    card_view:cardElevation="4dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Product Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp"
            android:background="#E0E0E0"
            android:gravity="center">

            <ImageView
                android:id="@+id/imgProduct"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="@string/no_image"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtImagePlaceholder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_image"
                android:textColor="#9E9E9E"
                android:textSize="16sp"
                android:textStyle="italic" />
        </FrameLayout>

        <!-- Title -->
        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#7B1FA2"
            android:layout_marginTop="8dp" />

        <!-- Info Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginTop="10dp">

            <!-- Tag Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FCE4EC"
                android:padding="8dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:id="@+id/txtTagLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tag_label"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7B1FA2" />

                <TextView
                    android:id="@+id/txtTagValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Price Card -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#FFF9C4"
                android:padding="8dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:id="@+id/txtPriceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/price_label"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#7B1FA2" />

                <TextView
                    android:id="@+id/txtPriceValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="#000000"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

        </LinearLayout>

        <!-- Description Title -->
        <TextView
            android:id="@+id/txtDescTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/description_label"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#7B1FA2"
            android:layout_marginTop="10dp" />

        <!-- Description Content -->
        <TextView
            android:id="@+id/txtDescription"
            android:layout_width="match_parent"
            android:layout_height="206dp"
            android:layout_marginTop="4dp"
            android:lineSpacingExtra="2dp"
            android:text=""
            android:textColor="#757575"
            android:textSize="14sp" />

        <!-- Button -->
        <Button
            android:id="@+id/btnWant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_want"
            android:contentDescription="@string/btn_want_desc"
            android:textAllCaps="true"
            android:textColor="@android:color/white"
            android:backgroundTint="#7B1FA2"
            android:layout_marginTop="12dp"
            android:padding="10dp"/>
    </LinearLayout>

</androidx.cardview.widget.CardView>